	keywords = {Artificial neural networks ({ANNs}), Economic forecasting, Evolutionary computation, Genetic algorithms, Kernel, Least squares methods, Machine learning, Predictive models, Stock markets, Support vector machines, Testing, evolutionary algorithms ({EAs}), feature selection, genetic algorithm ({GA}), least squares support vector machine ({LSSVM}), mixed kernel, parameter optimization, statistical models, stock market trend mining},
}

