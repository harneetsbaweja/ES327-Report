@misc{johnsonHowUsefulCrypto2023,
	location = {Rochester, {NY}},
	title = {How Useful is the Crypto Fear and Greed Index When Making Cryptocurrency Investment Decisions},
	url = {https://papers.ssrn.com/abstract=4407405},
	doi = {10.2139/ssrn.4407405},
	abstract = {An analysis of the relationships of both the price and trading volume of Bitcoin, Ethereum, Cardano, Avalanche and Dogecoin with the Crypto Fear  and Greed Index, whether the Index is used as a comparison with future prices or measured over a series of previous days, provides very patchy results, with very little agreement between cryptocurrencies.  The clearest results are derived when the Index is divided into greed, mid-range and fear but even then, nothing is consistent.  Measuring relationships over long periods should be avoided, but when divided into smaller groups, such as months, adjacent months can have totally different outcomes.  The Crypto Fear and Greed Index may give investors some idea of the current perception of some aspects of the cryptocurrency market but it is not useful as a tool for making investment decisions.},
	number = {4407405},
	publisher = {Social Science Research Network},
	author = {Johnson, Jackie},
	urldate = {2026-03-05},
	date = {2023-04-03},
	langid = {english},
	keywords = {Avalanche, Bitcoin, Cardano, Crypto Fear and Greed Index, Dogecoin, Ethereum},
}

